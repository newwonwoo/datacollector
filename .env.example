# collector 환경변수 예시 파일.
# 이 파일을 `.env` 로 복사한 뒤 실제 값을 채워 넣으세요.
#   cp .env.example .env
# `.env` 는 .gitignore 에 포함되어 Git에 커밋되지 않습니다.

# YouTube Data API v3 (무료, 10,000 units/day)
# 발급 방법: https://console.cloud.google.com/apis/credentials → "API 키 만들기"
YOUTUBE_API_KEY=AIzaSyAgMtPqjTl3oSzIzPGjaj3lVFrw7iM7_pQ

# Gemini API (무료 티어: 15 RPM / 1500 RPD) — 기본 LLM
# 발급 방법: https://aistudio.google.com/app/apikey → "Create API key"
GOOGLE_API_KEY=AIzaSyBBX7gVwJmTMnD1T_aeteT-hVP_S-eOfP8

# (선택) Anthropic Claude — 유료. 쓰려면 `collector run --llm anthropic`
# ANTHROPIC_API_KEY=sk-ant-...

# (선택) 기본 LLM 지정. 미설정 시 gemini.
# COLLECTOR_LLM=gemini

# (선택) GitHub App for Git Sync
# GH_APP_ID=123456
# GH_INSTALL_ID=789012
# GH_PRIVATE_KEY_PATH=/path/to/private-key.pem
